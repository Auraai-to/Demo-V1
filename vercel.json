{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api"
    }
  },
  "routes": [
    { "src": "/health", "dest": "backend" },
    { "src": "/api/(.*)", "dest": "backend" },
    { "src": "/(.*)", "dest": "frontend" }
  ]
}
